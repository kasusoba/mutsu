# Copy to `.env` and fill in. The real `.env` is gitignored.
# PartyKit `dev` reads `.env`; deploy uses `npx partykit env push`.

# OpenSubtitles API key (https://www.opensubtitles.com/consumers).
OPENSUBTITLES_API_KEY=
# Optional — logged-in downloads raise the daily limit to 20.
OS_USERNAME=
OS_PASSWORD=

# SubDL API key (https://subdl.com/panel/api) — free, generous limits.
SUBDL_API_KEY=

# Which providers to try, in order (comma-separated): opensubtitles,subdl
SUBS_PROVIDER_ORDER=opensubtitles,subdl

# GIPHY search key (https://developers.giphy.com) — fun-layer GIF reactions.
# A free beta key is fine (rate-limited to 100 searches/hour per key).
GIPHY_API_KEY=

# Video call (§17) — Cloudflare Realtime TURN, the relay used only when a direct
# peer-to-peer call can't be established. OPTIONAL: without these the call still
# works for most people via free STUN; these just cover the locked-down-network
# minority. Free up to 1,000 GB/mo. Create a TURN app at Cloudflare dash →
# Realtime → TURN, then paste the TURN key id + its API token.
TURN_KEY_ID=
TURN_KEY_API_TOKEN=
