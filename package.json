{
  "name": "mutsu",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:server": "pnpm --filter @mutsu/server dev",
    "dev:web": "pnpm --filter @mutsu/web dev",
    "dev:ext": "pnpm --filter @mutsu/extension dev",
    "deploy:server": "pnpm --filter @mutsu/server deploy",
    "deploy:web": "pnpm --filter @mutsu/web deploy:cf",
    "test:sync": "pnpm --filter @mutsu/server test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write . && prettier --write \"**/*.svelte\"",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.2",
    "typescript": "^5.7.2"
  }
}
